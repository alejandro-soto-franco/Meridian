# Top 25 namespaces by declaration count.
#
# Reasoning-agnostic: we walk rdf:type/rdfs:subClassOf* so the query works
# whether or not the triple store materialises subclass inferences.
PREFIX mer:  <https://meridian.sotofranco.dev/ontology#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?ns (COUNT(?d) AS ?n)
WHERE {
  ?d a/rdfs:subClassOf* mer:Declaration ;
     mer:inNamespace ?ns .
}
GROUP BY ?ns
ORDER BY DESC(?n)
LIMIT 25
