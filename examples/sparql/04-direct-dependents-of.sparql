# All declarations that directly depend on a chosen target. Edit the IRI
# below to point at whatever you want to analyse ("who breaks if I change X").
#
# Default target: Init.Prelude.Eq — appears in essentially every Mathlib
# theorem, so on a full dump this returns thousands of rows.
PREFIX mer: <https://meridian.sotofranco.dev/ontology#>

SELECT ?d
WHERE {
  ?d mer:directlyDependsOn
     <https://meridian.sotofranco.dev/lean/Init/Prelude#Eq> .
}
ORDER BY ?d
LIMIT 100
