# All sorry-bearing declarations and the count of declarations that depend on
# them directly. Highest downstream impact first.
PREFIX mer: <https://meridian.sotofranco.dev/ontology#>

SELECT ?d ?sorries (COUNT(?dep) AS ?downstream)
WHERE {
  ?d a mer:Declaration ;
     mer:hasSorry true ;
     mer:sorryCount ?sorries .
  OPTIONAL { ?dep mer:directlyDependsOn ?d . }
}
GROUP BY ?d ?sorries
ORDER BY DESC(?downstream)
LIMIT 50
