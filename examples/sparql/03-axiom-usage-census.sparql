# Census of axiom usage: which axioms are referenced, and by how many
# distinct declarations.
#
# Some dumps reference axioms that are not themselves typed as mer:Axiom in
# the same dump (e.g. when the dump is module-local and the axiom lives in
# Init). We use mer:usesAxiom directly without re-asserting the class.
PREFIX mer: <https://meridian.sotofranco.dev/ontology#>

SELECT ?axiom (COUNT(DISTINCT ?user) AS ?users)
WHERE {
  ?user mer:usesAxiom ?axiom .
}
GROUP BY ?axiom
ORDER BY DESC(?users)
LIMIT 25
